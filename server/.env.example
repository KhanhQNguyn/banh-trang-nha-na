PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/banh-trang-nha-na

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_secret_should_be_long_and_random
JWT_REFRESH_SECRET=your_jwt_refresh_secret_should_be_long_and_random
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Seed Admin (CLI seeder)
ADMIN_EMAIL=admin@banhtrangnhana.com
ADMIN_PASSWORD=adminPassword123
ADMIN_PHONE=0901234567
